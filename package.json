{
  "name": "repro-v2",
  "private": true,
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.11",
      "evlog": "^2.18.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start:local": "turbo start:local",
    "check-types": "turbo check-types",
    "dev:console": "turbo -F console dev",
    "dev:api": "turbo -F api dev",
    "dev:docs": "turbo -F docs dev",
    "dev:marketing": "turbo -F marketing dev",
    "db:push": "turbo -F @repro-v2/db db:push",
    "db:studio": "turbo -F @repro-v2/db db:studio",
    "db:generate": "turbo -F @repro-v2/db db:generate",
    "db:migrate": "turbo -F @repro-v2/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@repro-v2/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@repro-v2/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.10"
}
