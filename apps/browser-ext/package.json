{
  "name": "browser-ext",
  "version": "0.0.0",
  "private": true,
  "description": "manifest.json description",
  "type": "module",
  "scripts": {
    "dev": "wxt prepare && wxt --port 5555",
    "dev:firefox": "wxt prepare && wxt -b firefox",
    "build": "wxt prepare && wxt build",
    "build:firefox": "wxt prepare && wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check-types": "tsc --noEmit",
    "compile": "tsc --noEmit"
  },
  "dependencies": {
    "@repro-v2/api-client": "workspace:*",
    "@repro-v2/auth": "workspace:*",
    "@repro-v2/env": "workspace:*",
    "@repro-v2/ui": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
