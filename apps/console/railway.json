{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run --filter console build"
  },
  "deploy": {
    "startCommand": "bun run --filter console start",
    "healthcheckPath": "/api/ready",
    "restartPolicyType": "ON_FAILURE"
  }
}
