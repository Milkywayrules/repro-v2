# ── IAM features (true/false; default true when omitted) ─────────────────────
IAM_EMAIL_PASSWORD_ENABLED=true
IAM_MAGIC_LINK_ENABLED=true
IAM_GITHUB_ENABLED=true
IAM_WORKSPACE_ENABLED=true
IAM_MULTI_SESSION_ENABLED=true
IAM_CAPTCHA_ENABLED=true

# ── IAM core (Better Auth) ───────────────────────────────────────────────────
IAM_BETTER_AUTH_SECRET=I7BwOCXzfNHRUkyF6Gnzk5zJ6K2cyNT1
IAM_BETTER_AUTH_URL=http://localhost:5000

# ── IAM GitHub (required when IAM_GITHUB_ENABLED=true) ───────────────────────
# IAM_GITHUB_CLIENT_ID=
# IAM_GITHUB_CLIENT_SECRET=

# ── Turnstile platform ───────────────────────────────────────────────────────
TURNSTILE_ENABLED=false
# TURNSTILE_SECRET_KEY=  # required when TURNSTILE_ENABLED=true and IAM_CAPTCHA_ENABLED=true

# ── Email (required when IAM_MAGIC_LINK_ENABLED=true) ────────────────────────
# EMAIL_RESEND_API_KEY=

# ── Platform ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5001,http://localhost:5002,http://localhost:5009
# Production MV3 extension origins (comma-separated chrome-extension://…)
# EXTENSION_TRUSTED_ORIGINS=chrome-extension://your-extension-id
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Rate limiting (optional — defaults shown)
# RATE_LIMIT_AUTH_MAX=15
# RATE_LIMIT_AUTH_DURATION_MS=60000
# RATE_LIMIT_GLOBAL_MAX=200
# RATE_LIMIT_GLOBAL_DURATION_MS=60000
# RATE_LIMIT_DEV_MULTIPLIER=10

# OpenAPI (disabled in production unless true)
# OPENAPI_ENABLED=false

# Database seed (refused in production unless true)
# ALLOW_SEED=false
# SEED_USER_ID=00000000-0000-7000-8000-000000000001
