{
  "name": "api",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": {
      "types": "./dist-types/app.d.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "prepare": "tsc -b",
    "check-types": "tsc -b",
    "test": "bun test src",
    "build:tsdown": "tsdown",
    "start:tsdown": "bun run dist/index.mjs",
    "dev": "bun --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ./dist/api ./src/index.ts",
    "start": "./dist/api",
    "start:local": "./dist/api"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@repro-v2/api-schemas": "workspace:*",
    "@repro-v2/api-types": "workspace:*",
    "@repro-v2/iam": "workspace:*",
    "@repro-v2/db": "workspace:*",
    "@repro-v2/env": "workspace:*",
    "@repro-v2/s3": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "evlog": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repro-v2/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
