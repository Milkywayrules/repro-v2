    "@repro-v2/env": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "evlog": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repro-v2/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
