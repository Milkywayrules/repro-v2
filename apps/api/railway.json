{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run --filter api build"
  },
  "deploy": {
    "startCommand": "bun run --filter api start",
    "healthcheckPath": "/ready",
    "preDeployCommand": ["bun run --filter @repro-v2/db db:migrate"],
    "restartPolicyType": "ON_FAILURE"
  }
}
