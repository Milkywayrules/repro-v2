{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run --filter marketing build"
  },
  "deploy": {
    "startCommand": "bun run --filter marketing start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
