{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install --frozen-lockfile --filter marketing... && bun run --filter marketing build",
    "watchPatterns": [
      "apps/marketing/**",
      "packages/**",
      "package.json",
      "bun.lock"
    ]
  },
  "deploy": {
    "startCommand": "bun run --filter marketing start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
