{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install --frozen-lockfile --filter docs... && bun run --filter docs build",
    "watchPatterns": ["apps/docs/**", "packages/**", "package.json", "bun.lock"]
  },
  "deploy": {
    "startCommand": "bun run --filter docs start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
