    },
    "linter": {
      /** @default true - Enable CSS linter */
      "enabled": true
    },
    "assist": {
      /** @default true - Enable CSS assist */
      "enabled": true
    },
    /** @default [] - CSS global variables */
    "globals": []
  },
  "html": {
    "parser": {
      /** @default null - Interpolation syntax */
      "interpolation": null
    },
    "formatter": {
      /** @default true - Enable HTML formatter */
      "enabled": true,
      /** @default "tab" - Indentation style */
      "indentStyle": "space",
      /** @default 2 - Indentation width */
      "indentWidth": 2,
      /** @default "lf" - Line ending */
      "lineEnding": "lf",
      /** @default 80 - Line width */
      "lineWidth": 80,
      /** @default false - Indent <script> and <style> contents */
      "indentScriptAndStyle": false,
      /** @default "always" - Self-close void elements: "always", "never" */
      "selfCloseVoidElements": "always",
      /** @default null - Attribute position (inherits from top-level) */
      "attributePosition": null,
      /** @default null - Bracket same line (inherits from top-level) */
      "bracketSameLine": null,
      /** @default null - Whitespace sensitivity: "css", "strict", "ignore" */
      "whitespaceSensitivity": null
    },
    "linter": {
      /** @default true - Enable HTML linter */
      "enabled": true
    },
    "assist": {
      /** @default true - Enable HTML assist */
      "enabled": true
    },
    /** @default false - Enable experimental full HTML support */
    "experimentalFullSupportEnabled": false
  },
  /** @default null - Configuration overrides for specific files/patterns */
  "overrides": [
    {
      "includes": ["apps/browser-ext/**"],
      "javascript": {
        "globals": ["defineBackground", "defineContentScript", "browser"]
      }
    },
    {
      "includes": [
        "apps/console/src/app/**/page.tsx",
        "apps/marketing/src/app/**/page.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ],
  /** @default null - List of plugins to load */
  "plugins": null
