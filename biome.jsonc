  "assist": {
    /** @default true - Enable code assist actions */
    "enabled": true,
    /** @default null - Files to assist (null = all) */
    "includes": null,
    "actions": {
      /** @default true - Enable recommended assist actions */
      "recommended": true,
      "source": {
        /** @default true - Enable recommended source actions */
        "recommended": true,
        "organizeImports": {
          /** @default "on" - Enable organize imports action */
          "level": "on",
          "options": {
            /** @default [":URL:", ":NODE:", ":BUILTIN:", ":THIRD_PARTY:", ":LOCAL:"] */
            "groups": [
              "react",
              "next",
              "next/*",
              ":BLANK_LINE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              ":ALIAS:",
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "javascript": {
    "parser": {
      /** @default false - Enable unsafe parameter decorators */
      "unsafeParameterDecoratorsEnabled": false,
      /** @default false - Allow JSX syntax everywhere */
      "jsxEverywhere": true,
      /** @default null - GritQL metavariables */
      "gritMetavariables": null
    },
    "formatter": {
      /** @default true - Enable JavaScript formatter */
      "enabled": true,
      /** @default "tab" - Indentation style */
      "indentStyle": "space",
      /** @default 2 - Indentation width */
      "indentWidth": 2,
      /** @default "lf" - Line ending */
      "lineEnding": "lf",
      /** @default 80 - Line width */
      "lineWidth": 80,
      /** @default "double" - Quote style for strings */
      "quoteStyle": "single",
      /** @default "double" - Quote style for JSX attributes */
      "jsxQuoteStyle": "double",
      /** @default "asNeeded" - Quote object properties: "asNeeded", "preserve" */
      "quoteProperties": "asNeeded",
      /** @default "all" - Trailing commas: "all", "es5", "none" */
      "trailingCommas": "all",
      /** @default "always" - Semicolons: "always", "asNeeded" */
      "semicolons": "asNeeded",
      /** @default "always" - Arrow function parentheses: "always", "asNeeded" */
      "arrowParentheses": "asNeeded",
      /** @default false - Put closing bracket on same line */
      "bracketSameLine": false,
      /** @default true - Print spaces between brackets */
      "bracketSpacing": true,
      /** @default "auto" - Attribute position */
      "attributePosition": "auto",
      /** @default "auto" - Expand short syntax */
      "expand": "auto",
      /** @default "after" - Operator line break: "after", "before", "none" */
      "operatorLinebreak": "after"
    },
    /** @default [] - Global variables */
    "globals": [],
    /** @default "transparent" - JSX runtime: "transparent", "reactClassic" */
    "jsxRuntime": "transparent",
    "linter": {
      /** @default true - Enable JavaScript linter */
      "enabled": true
    },
    "assist": {
      /** @default true - Enable JavaScript assist */
      "enabled": true
    }
  },
  "json": {
    "parser": {
      /** @default false - Allow comments in JSON files */
      "allowComments": false,
      /** @default false - Allow trailing commas in JSON files */
      "allowTrailingCommas": true
    },
    "formatter": {
      /** @default true - Enable JSON formatter */
      "enabled": true,
      /** @default "tab" - Indentation style */
      "indentStyle": "space",
      /** @default 2 - Indentation width */
      "indentWidth": 2,
      /** @default "lf" - Line ending */
      "lineEnding": "lf",
      /** @default 80 - Line width */
      "lineWidth": 80,
      /** @default "none" - Trailing commas: "all", "none" */
      "trailingCommas": "none",
      /** @default null - Bracket spacing (inherits from top-level) */
      "bracketSpacing": null,
      /** @default null - Expand (inherits from top-level) */
      "expand": null
    },
    "linter": {
      /** @default true - Enable JSON linter */
      "enabled": true
    },
    "assist": {
      /** @default true - Enable JSON assist */
      "enabled": true
    }
  },
  "css": {
    "parser": {
