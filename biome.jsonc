      "allowWrongLineComments": null,
      /** @default false - Enable Tailwind CSS directives */
      "tailwindDirectives": true
    },
    "formatter": {
      /** @default true - Enable CSS formatter */
      "enabled": true,
      /** @default "tab" - Indentation style */
      "indentStyle": "space",
      /** @default 2 - Indentation width */
      "indentWidth": 2,
      /** @default "lf" - Line ending */
      "lineEnding": "lf",
      /** @default 80 - Line width */
      "lineWidth": 80,
      /** @default "double" - Quote style */
